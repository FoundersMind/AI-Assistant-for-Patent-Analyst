# Copy to .env and fill in. Never commit real secrets.

# Required for chat / AI features
GROQ_API_KEY=

# Optional (default: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=0
# Comma-separated hostnames only (no https://). Render/Vercel hosts are auto-added from RENDER_EXTERNAL_HOSTNAME / VERCEL_URL; .vercel.app is always allowed.
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,lumenci.onrender.com,.vercel.app

# Full https:// origins for CSRF (comma-separated). Render/Vercel https://<host> is auto-added from platform env.
DJANGO_CSRF_TRUSTED_ORIGINS=https://lumenci.onrender.com